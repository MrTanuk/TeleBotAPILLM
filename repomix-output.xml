SUPABASE_KEY = os.getenv("SUPABASE_KEY")
supabase: Client = None

if SUPABASE_URL and SUPABASE_KEY:
    supabase = Client(SUPABASE_URL, SUPABASE_KEY)
    
# --- Webhook & Hosting Configuration ---
WEBHOOK_URL = os.getenv("WEBHOOK_URL")
