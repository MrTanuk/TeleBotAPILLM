# Telegram Credentials
BOT_TOKEN=

# AI Provider (google / openai / deepseek / groq / nvidia)
PROVIDER=google
API_TOKEN=
LLM_MODEL=gemini-1.5-flash
# Base URL for Google:   https://generativelanguage.googleapis.com/v1beta/models
# Base URL for OpenAI:   https://api.openai.com/v1/chat/completions
# Base URL for DeepSeek: https://api.deepseek.com/chat/completions
# Base URL for Groq:     https://api.groq.com/openai/v1/chat/completions
# Base URL for NVIDIA:   https://integrate.api.nvidia.com/v1/chat/completions
API_URL=https://generativelanguage.googleapis.com/v1beta/models
SYSTEM_MESSAGE="You are a helpful assistant."
# ~1 token ≈ 3–4 chars. 1024 tokens ≈ 3000–4000 chars (Telegram limit: 4096).
MAX_OUTPUT_TOKENS=1024

# Audio Transcription (Groq Whisper — independent from the main LLM provider)
# If not set, falls back to API_TOKEN (only works if your provider is also Groq).
GROQ_API_KEY=

# Hosting (development / production)
HOSTING=development
WEBHOOK_URL=
PORT=8080
# Optional: validates that webhook requests come from Telegram (recommended in production).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=
